{
  "name": "prismly-cli",
  "version": "0.1.4",
  "description": "Reads local AI coding assistant usage logs and computes token usage/cost, with an interactive terminal UI.",
  "keywords": [
    "claude-code",
    "cli",
    "usage",
    "cost",
    "tokens",
    "terminal",
    "tui"
  ],
  "author": "Vilck Farias",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VilckFarias/Prismly.git"
  },
  "homepage": "https://github.com/VilckFarias/Prismly#readme",
  "bugs": {
    "url": "https://github.com/VilckFarias/Prismly/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "prismly-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "start": "node --experimental-strip-types index.ts",
    "test": "node --experimental-strip-types --test core/**/*.test.ts cli/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:* --external:ink --external:react",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0"
  }
}
