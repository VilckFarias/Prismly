{
  "name": "prismly-cli",
  "version": "0.1.2",
  "description": "Reads local AI coding assistant usage logs and computes token usage/cost.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "prismly-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "start": "node index.ts",
    "test": "node --test core/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:*",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.0"
  }
}
